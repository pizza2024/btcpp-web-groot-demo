{
  "name": "btcpp-web-groot-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/bt-editor.cjs.js",
  "module": "./dist/bt-editor.es.js",
  "exports": {
    ".": {
      "import": "./dist/bt-editor.es.js",
      "require": "./dist/bt-editor.cjs.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:web && pnpm run build:lib",
    "build:web": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.10.2",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
